# 环境变量示例文件
# 复制为 .env 并填入实际值

# ────────────────────────────────────────────────────────────────
# 测试环境
# ────────────────────────────────────────────────────────────────
TEST_ENV=dev

# 被测系统 URL
BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:3000/api/v1

# ────────────────────────────────────────────────────────────────
# 测试账号 (请使用独立的测试账号，不要使用生产账号)
# ────────────────────────────────────────────────────────────────

# 校务主任 (管理员)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Test@2026

# 校务处同工
OFFICER_USERNAME=officer01
OFFICER_PASSWORD=Test@2026

# 教师
TEACHER_USERNAME=teacher01
TEACHER_PASSWORD=Test@2026

# 家长
PARENT_USERNAME=parent01
PARENT_PASSWORD=Test@2026
PARENT_PHONE=+85290000001

# ────────────────────────────────────────────────────────────────
# 第三方服务 Mock
# ────────────────────────────────────────────────────────────────
# 飞书 OAuth (测试环境)
FEISHU_APP_ID=test_app_id
FEISHU_APP_SECRET=test_app_secret

# 短信 OTP (测试)
OTP_MOCK_ENABLED=true

# ────────────────────────────────────────────────────────────────
# 数据库 (测试用)
# ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://test:test@localhost:5432/school_admin_test

# ────────────────────────────────────────────────────────────────
# CI 环境
# ────────────────────────────────────────────────────────────────
CI=false
