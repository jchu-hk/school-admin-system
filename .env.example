# ============================================================
# Smart School Admin - Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# ---- Application ----
NODE_ENV=development
PORT=3000
APP_NAME=SmartSchoolAdmin

# ---- Database ----
DB_HOST=localhost
DB_PORT=5432
DB_USER=school_admin
DB_PASSWORD=your_secure_password_here
DB_NAME=school_admin
DB_SSL=false

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- JWT ----
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d

# ---- OPA (ABAC Policy Engine) ----
OPA_URL=http://localhost:8181

# ---- Notification Channels ----
# Options: mock, feishu, email, sms
NOTIFICATION_CHANNEL=mock

# ---- Feishu (Lark) Integration ----
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BOT_TOKEN=

# ---- AI Service (Coze) ----
COZE_API_KEY=
COZE_BOT_ID=

# ---- Monitoring ----
PROMETHEUS_PORT=9091
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123

# ---- Kafka ----
KAFKA_PORT=9092

# ---- Frontend ----
FRONTEND_PORT=8080
FRONTEND_API_URL=http://localhost:3000/api

# ---- Logging ----
LOG_LEVEL=info

# ---- Security ----
SESSION_SECURE_COOKIE=false
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000
